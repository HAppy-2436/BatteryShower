{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BatteryShower",
  "version": "0.1.0",
  "identifier": "com.happy-2436.batteryshower",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BatteryShower",
        "width": 960,
        "height": 640,
        "minWidth": 600,
        "minHeight": 400,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Taskbar battery power monitor",
    "longDescription": "BatteryShower is a lightweight Windows taskbar utility that displays real-time battery charge/discharge power with a clean numeric overlay, with historical curves for the most recent charge/discharge session.",
    "publisher": "HAppy-2436",
    "homepage": "https://github.com/HAppy-2436/BatteryShower",
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      }
    }
  }
}
